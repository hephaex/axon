# Axon Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# API Keys
# ============================================

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT)
OPENAI_API_KEY=sk-your-key-here

# Google (Gemini)
GOOGLE_API_KEY=your-key-here

# ============================================
# Server Configuration
# ============================================

# Axon server port
AXON_PORT=8090

# Ollama port (when using with-ollama profile)
OLLAMA_PORT=11434

# Log level
RUST_LOG=axon=info

# ============================================
# Optional: MinKy Integration
# ============================================

# MinKy API endpoint
# MINKY_ENDPOINT=http://localhost:3000/api
# MINKY_API_KEY=your-minky-key
